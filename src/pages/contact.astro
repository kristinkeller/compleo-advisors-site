---
import SiteLayout from '../layouts/SiteLayout.astro';
---
<SiteLayout title="Contact · Compleo Advisors" description={"Tell us what you're working on. Compleo Advisors responds within two business days, and the first conversation is yours to use."} slug="contact" pathname="/contact" active="contact">

<section class="hero">
  <div class="container">
    <div class="hero-inner reveal">
      <div class="hero-eyebrow">Contact</div>
      <h1>Let's talk about <span class="accent">where you're going</span>.</h1>
      <p class="hero-sub">Tell us what you're working on, what's coming up, and what would be most useful to think through together. You'll get a thoughtful reply within two business days. The first conversation is yours to use: think through a challenge, pressure-test a direction, or get a second view from inside the field.</p>
    </div>
  </div>
</section>

<section class="form-section">
  <div class="container">
    <div class="form-grid">
      <form class="contact-form reveal" id="contactForm" action="#" method="post">
        <div class="form-row">
          <div class="form-field">
            <label for="f-name">Name<span class="required">*</span></label>
            <input id="f-name" name="name" type="text" required placeholder="Your name">
          </div>
          <div class="form-field">
            <label for="f-email">Email<span class="required">*</span></label>
            <input id="f-email" name="email" type="email" required placeholder="you@organization.com">
          </div>
        </div>

        <div class="form-row">
          <div class="form-field">
            <label for="f-org">Organization</label>
            <input id="f-org" name="organization" type="text" placeholder="Company or organization">
          </div>
          <div class="form-field">
            <label for="f-role">Your role</label>
            <input id="f-role" name="role" type="text" placeholder="Title or function">
          </div>
        </div>

        <div class="form-field full">
          <label for="f-type">What kind of organization?</label>
          <select id="f-type" name="org_type">
            <option value="">Select one</option>
            <option value="biotech">Rare disease biotech</option>
            <option value="advocacy">Advocacy organization</option>
            <option value="pharma_services">Pharma marketing services company</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div class="form-field full">
          <label for="f-message">What would you like to discuss?<span class="required">*</span></label>
          <textarea id="f-message" name="message" required maxlength="500" placeholder="A sentence or two on what's on your mind."></textarea>
          <span class="char-hint">A few sentences is plenty.</span>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Start the conversation <span class="arrow">→</span></button>
          <span class="privacy">We respond within two business days. Your information is kept private and never shared.</span>
        </div>
      </form>

      <aside class="contact-aside reveal">
        <div class="aside-card">
          <h3>Or write directly.</h3>
          <p><a href="mailto:kristin@compleoadvisors.com">kristin@compleoadvisors.com</a></p>
        </div>
        <div class="aside-card">
          <h3>Connect on LinkedIn.</h3>
          <p><a href="https://www.linkedin.com/company/compleo-advisors/" rel="noopener noreferrer">linkedin.com/company/compleo-advisors</a></p>
          <p><a href="https://www.linkedin.com/in/kristinkeller/" rel="noopener noreferrer">linkedin.com/in/kristinkeller</a></p>
        </div>
        <div class="aside-card">
          <h3>Boston, Massachusetts.</h3>
          <p>Compleo Advisors works with clients across North America and Europe.</p>
        </div>
      </aside>
    </div>
  </div>
</section>

<section class="next">
  <div class="container">
    <div class="next-header reveal">
      <p class="eyebrow" style="text-align:center;">What happens next</p>
      <h2>From here to a useful conversation.</h2>
    </div>

    <div class="next-grid">
      <article class="next-step reveal">
        <div class="step-num">1</div>
        <h3>You'll hear back within two business days.</h3>
        <p>A real reply, written by Kristin Marvin Keller, built around what you sent.</p>
      </article>
      <article class="next-step reveal">
        <div class="step-num">2</div>
        <h3>We schedule a 30-minute conversation.</h3>
        <p>A call to understand what you are working on, what's coming up, and how Compleo Advisors can help.</p>
      </article>
      <article class="next-step reveal">
        <div class="step-num">3</div>
        <h3>We follow up with what we heard.</h3>
        <p>Whether the next step is a real engagement or a useful introduction, you leave the conversation with something.</p>
      </article>
    </div>
  </div>
</section>

<script>
  // Contact form → opens user's email client with all form fields pre-filled.
  // v1 mechanism. For production, swap to a Formspree endpoint or Cloudflare
  // Pages Function with MailChannels to email directly without leaving the page.
  document.getElementById('contactForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const f = e.target;
    const get = (n) => (f.querySelector('[name="' + n + '"]')?.value || '').trim();
    const name  = get('name');
    const email = get('email');
    const org   = get('organization');
    const role  = get('role');
    const type  = get('org_type');
    const msg   = get('message');
    if (!name || !email || !msg) return;

    const subject = encodeURIComponent('Conversation request from ' + name);
    const body = encodeURIComponent(
      "Hi Kristin — a new conversation request from compleoadvisors.com/contact:\n\n" +
      "Name: " + name + "\n" +
      "Email: " + email + "\n" +
      "Organization: " + (org || '—') + "\n" +
      "Role: " + (role || '—') + "\n" +
      "Organization type: " + (type || '—') + "\n\n" +
      "What they want to discuss:\n" + msg + "\n"
    );
    window.location.href = 'mailto:kristin@compleoadvisors.com?subject=' + subject + '&body=' + body;
  });
</script>
</SiteLayout>

<style is:global>
/* COMPLEO ADVISORS — CONTACT MOCKUP v1 */
/* tokens in global.css */
*,*::before,*::after{box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{margin:0;font-family:var(--font-stack);font-size:var(--fs-body);line-height:var(--lh-body);color:var(--c-body);background:var(--c-white);-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;text-rendering:optimizeLegibility;}
img,svg{display:block;max-width:100%;}
a{color:var(--c-charcoal);text-decoration:none;transition:color .15s ease;}
a:hover{color:var(--c-amber);}
h1,h2,h3,h4{font-family:var(--font-stack);color:var(--c-near-black);margin:0;line-height:var(--lh-tight);letter-spacing:-0.01em;}
h1{font-size:var(--fs-h1-desktop);font-weight:600;letter-spacing:-0.02em;}
h2{font-size:var(--fs-h2-desktop);font-weight:600;}
h3{font-size:var(--fs-h3-desktop);font-weight:500;line-height:var(--lh-snug);}
p{margin:0 0 1em;}
p:last-child{margin-bottom:0;}
.container{width:100%;max-width:var(--content-max);margin:0 auto;padding:0 var(--gutter);}
.container-narrow{width:100%;max-width:var(--content-narrow);margin:0 auto;padding:0 var(--gutter);}
section{padding:var(--section-y-desktop) 0;}
.eyebrow{font-size:var(--fs-small);font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--c-amber);margin:0 0 16px;}

.btn{display:inline-flex;align-items:center;gap:10px;padding:14px 28px;font-family:var(--font-stack);font-size:16px;font-weight:500;border-radius:var(--radius);border:none;cursor:pointer;transition:background .18s ease,color .18s ease,border-color .18s ease,transform .18s ease;}
.btn-primary{background:var(--c-amber);color:var(--c-white);}
.btn-primary:hover{background:var(--c-charcoal);color:var(--c-white);}
.btn .arrow{display:inline-block;transition:transform .18s ease;}
.btn:hover .arrow{transform:translateX(4px);}

/* HEADER */
.site-header{position:sticky;top:0;z-index:100;background:rgba(255,255,255,0.96);backdrop-filter:saturate(180%) blur(10px);-webkit-backdrop-filter:saturate(180%) blur(10px);border-bottom:var(--rule);}
.nav{display:flex;align-items:center;justify-content:space-between;padding:18px 0;}
.brand{display:flex;align-items:center;gap:12px;color:var(--c-near-black);}
.brand-mark{width:36px;height:36px;}
.brand-words{display:flex;flex-direction:column;line-height:1;}
.brand-name{font-weight:600;font-size:18px;color:var(--c-charcoal);letter-spacing:-0.005em;}
.nav-links{display:flex;align-items:center;gap:28px;list-style:none;padding:0;margin:0;}
.nav-links a{font-size:15px;font-weight:500;color:var(--c-charcoal);}
.nav-links a.active{color:var(--c-amber);}
.nav-cta{margin-left:10px;padding:10px 20px;background:var(--c-amber);color:var(--c-white)!important;border-radius:var(--radius);font-weight:500;}
.nav-cta:hover{background:var(--c-charcoal);color:var(--c-white)!important;}
.nav-toggle{display:none;background:none;border:none;cursor:pointer;color:var(--c-charcoal);font-size:22px;padding:8px;}

/* HERO */
.hero{position:relative;padding:84px 0 40px;overflow:hidden;}
.hero-inner{max-width:920px;}
.hero-eyebrow{display:inline-flex;align-items:center;gap:14px;font-size:13px;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:var(--c-mid-gray);margin-bottom:32px;}
.hero-eyebrow::before{content:"";display:inline-block;width:48px;height:2px;background:var(--c-amber);}
.hero h1{font-size:clamp(40px,6.2vw,72px);line-height:1.06;font-weight:600;color:var(--c-near-black);margin-bottom:24px;max-width:18ch;letter-spacing:-0.025em;}
.hero h1 .accent{color:var(--c-amber);background-image:linear-gradient(var(--c-amber),var(--c-amber));background-size:100% 6px;background-position:0 96%;background-repeat:no-repeat;padding-bottom:2px;}
.hero-sub{font-size:clamp(19px,2vw,22px);line-height:1.5;color:var(--c-charcoal);max-width:60ch;font-weight:400;}

/* FORM + ASIDE */
.form-section{padding-top:48px;padding-bottom:var(--section-y-desktop);}
.form-grid{display:grid;grid-template-columns:1.5fr 1fr;gap:64px;align-items:start;}

/* FORM */
.contact-form{background:var(--c-white);border:1px solid var(--c-rule-gray);border-radius:var(--radius);padding:40px 40px 36px;box-shadow:0 18px 36px -22px rgba(74,74,74,0.18);}
.contact-form .form-row{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:18px;}
.contact-form .form-field{display:flex;flex-direction:column;margin-bottom:18px;}
.contact-form .form-field.full{margin-bottom:18px;}
.contact-form label{font-size:13px;font-weight:600;color:var(--c-charcoal);margin-bottom:8px;letter-spacing:0.02em;}
.contact-form label .required{color:var(--c-amber);margin-left:3px;}
.contact-form input,
.contact-form select,
.contact-form textarea{font-family:var(--font-stack);font-size:16px;color:var(--c-near-black);background:var(--c-white);border:1.5px solid var(--c-rule-gray);border-radius:var(--radius);padding:12px 14px;transition:border-color .15s ease,box-shadow .15s ease;width:100%;}
.contact-form input::placeholder,
.contact-form textarea::placeholder{color:var(--c-mid-gray);}
.contact-form input:focus,
.contact-form select:focus,
.contact-form textarea:focus{outline:none;border-color:var(--c-amber);box-shadow:0 0 0 3px rgba(237,145,5,0.18);}
.contact-form textarea{resize:vertical;min-height:120px;font-family:var(--font-stack);line-height:1.5;}
.contact-form select{appearance:none;background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='12' height='8' viewBox='0 0 12 8' fill='none'><path d='M1 1.5L6 6.5L11 1.5' stroke='%234A4A4A' stroke-width='1.6' stroke-linecap='round'/></svg>");background-repeat:no-repeat;background-position:right 14px center;padding-right:36px;}
.contact-form .char-hint{font-size:12px;color:var(--c-mid-gray);margin-top:6px;font-style:italic;}
.form-actions{margin-top:8px;display:flex;flex-direction:column;align-items:flex-start;gap:14px;}
.form-actions .btn{padding:14px 32px;}
.form-actions .privacy{font-size:13px;color:var(--c-mid-gray);line-height:1.5;}

/* ASIDE */
.contact-aside{display:flex;flex-direction:column;gap:32px;padding-top:6px;}
.aside-card h3{font-size:18px;font-weight:600;color:var(--c-near-black);margin-bottom:14px;border-left:3px solid var(--c-amber);padding-left:14px;line-height:1.3;}
.aside-card p{font-size:15px;line-height:1.55;color:var(--c-charcoal);margin-bottom:8px;padding-left:17px;}
.aside-card a{color:var(--c-amber);font-weight:500;}

/* WHAT HAPPENS NEXT */
.next{background:var(--c-warm-cream);}
.next-header{text-align:center;margin-bottom:40px;}
.next-header h2{margin-bottom:14px;}
.next-header p{color:var(--c-charcoal);font-size:17px;max-width:600px;margin:0 auto;}
.next-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;max-width:1080px;margin:0 auto;}
.next-step{position:relative;background:var(--c-white);border:1px solid rgba(237,145,5,0.18);border-radius:var(--radius);padding:32px 28px 28px;}
.next-step .step-num{position:absolute;top:-18px;left:24px;width:38px;height:38px;display:flex;align-items:center;justify-content:center;background:var(--c-amber);color:var(--c-white);font-weight:600;font-size:16px;border-radius:99px;letter-spacing:0.02em;}
.next-step h3{font-size:19px;font-weight:600;color:var(--c-near-black);margin:8px 0 12px;line-height:1.3;letter-spacing:-0.01em;}
.next-step p{font-size:15px;line-height:1.55;color:var(--c-charcoal);}

/* FOOTER */
.site-footer{background:var(--c-near-black);color:#B3B3B3;padding:64px 0 32px;font-size:14px;}
.footer-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:48px;margin-bottom:48px;}
.footer-brand .brand-name{color:var(--c-white);}
.footer-tag{margin-top:16px;color:#B3B3B3;max-width:32ch;line-height:1.5;}
.footer-col h4{font-size:12px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:var(--c-amber);margin-bottom:16px;}
.footer-col ul{list-style:none;padding:0;margin:0;}
.footer-col li{margin-bottom:10px;}
.footer-col a{color:#B3B3B3;}
.footer-col a:hover{color:var(--c-white);}
.footer-bottom{border-top:1px solid #444;padding-top:24px;display:flex;justify-content:space-between;align-items:center;font-size:13px;color:#777;}

/* REVEAL */
.reveal{opacity:0;transform:translateY(14px);transition:opacity .7s ease,transform .7s ease;}
.reveal.in{opacity:1;transform:none;}

/* RESPONSIVE */
@media (max-width:960px){
  :root{--section-y-desktop:var(--section-y-mobile);}
  body{font-size:var(--fs-body-mobile);}
  h1{font-size:var(--fs-h1-mobile);}
  h2{font-size:var(--fs-h2-mobile);}
  h3{font-size:var(--fs-h3-mobile);}
  .nav-links{display:none;}
  .nav-toggle{display:block;}
  .nav.open .nav-links{display:flex;flex-direction:column;align-items:flex-start;gap:18px;position:absolute;top:100%;left:0;right:0;background:var(--c-white);padding:24px var(--gutter);border-bottom:var(--rule);}
  .hero{padding:64px 0 32px;}
  .hero h1{font-size:38px;max-width:100%;margin-bottom:18px;}
  .hero-sub{font-size:18px;}
  .hero-eyebrow{margin-bottom:24px;}
  .form-grid{grid-template-columns:1fr;gap:36px;}
  .contact-form{padding:28px 24px;}
  .contact-form .form-row{grid-template-columns:1fr;gap:0;margin-bottom:0;}
  .next-grid{grid-template-columns:1fr;gap:24px;}
  .footer-grid{grid-template-columns:1fr;gap:32px;}
  .footer-bottom{flex-direction:column;gap:12px;text-align:center;}
}

/* ─── Accessibility & Print ─── */
.skip-link{position:absolute;top:-40px;left:0;background:var(--c-amber);color:var(--c-white);padding:10px 18px;z-index:200;text-decoration:none;border-radius:0 0 var(--radius) 0;font-weight:500;}
.skip-link:focus{top:0;color:var(--c-white);outline:none;}
:focus-visible{outline:2px solid var(--c-amber);outline-offset:3px;border-radius:3px;}
button:focus-visible,a:focus-visible,input:focus-visible,select:focus-visible,textarea:focus-visible{outline:2px solid var(--c-amber);outline-offset:3px;}

@media (prefers-reduced-motion:reduce){
  html{scroll-behavior:auto;}
  *,*::before,*::after{transition-duration:0.001ms!important;animation-duration:0.001ms!important;animation-iteration-count:1!important;}
  .reveal{opacity:1!important;transform:none!important;}
}

@media print{
  *{background:transparent!important;color:#000!important;box-shadow:none!important;text-shadow:none!important;}
  .site-header,.site-footer,.nav-toggle,.nav-cta,.cta-row,.btn,.hero-eyebrow::before,.amber-rule,.signup,.closing,.next,.form-section,#navToggle,.nav-links{display:none!important;}
  body{font-size:11pt;line-height:1.45;background:#fff!important;}
  h1{font-size:24pt;}
  h2{font-size:18pt;}
  h3{font-size:14pt;}
  .container,.container-narrow,.container-reading,.hero-inner{max-width:100%!important;padding:0!important;}
  section{padding:18pt 0!important;page-break-inside:avoid;}
  a{color:#000!important;text-decoration:underline;}
  a[href^="http"]:after{content:" ("attr(href)")";font-size:9pt;color:#555;}
  .reveal{opacity:1!important;transform:none!important;}
  .hero h1 .accent{background:none!important;padding-bottom:0!important;}
}
</style>
